# === Auto Idea Combiner - 環境変数サンプル ===
# このファイルをコピーして .env を作成し、各キーを設定してください
# cp .env.example .env

# --- LLM プロバイダー設定 ---
# メインで使用するLLM: anthropic / openai / gemini
LLM_PROVIDER=anthropic

# Anthropic API Key (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# --- Embedding 設定 ---
# ローカルモデル(sentence-transformers)またはAPIを指定
# local / openai
EMBEDDING_PROVIDER=local
# ローカル使用時のモデル名
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- 外部API ---
NEWS_API_KEY=your_newsapi_key_here
GITHUB_TOKEN=your_github_token_here

# --- アプリ設定 ---
# バックエンドAPIのポート
BACKEND_PORT=8765
# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# --- データ収集設定 ---
# ローカルファイル収集対象ディレクトリ（カンマ区切り）
LOCAL_SCAN_DIRS=~/Documents,~/Desktop
# クリップボード監視: true / false
CLIPBOARD_WATCH=true
# 外部API使用: true / false
EXTERNAL_API_ENABLED=true

# --- ChromaDB 設定 ---
CHROMA_PERSIST_DIR=./chroma_data

# --- スコアリング重み（合計1.0になること）---
SCORE_WEIGHT_NOVELTY=0.22
SCORE_WEIGHT_RELEVANCE=0.18
SCORE_WEIGHT_DISTANCE=0.18
SCORE_WEIGHT_FEASIBILITY=0.16
SCORE_WEIGHT_FUN=0.16
SCORE_WEIGHT_API_FIT=0.10
