{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Idea Combiner",
  "version": "0.1.0",
  "identifier": "com.auto-idea-combiner.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Auto Idea Combiner",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
